<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AgencyMCP — AI runs your ads, analytics, and SEO</title>
<meta name="description" content="Connect Google Ads, Meta Ads, GA4, Search Console & Sheets to Claude. 350+ AI tools that optimize your marketing 24/7.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#050507;--bg2:#0a0a10;--bg3:#111118;--bg4:#1a1a24;
  --text:#f0f0f5;--text2:#a0a0b8;--text3:#6a6a80;
  --accent:#7c6aff;--accent2:#9b8aff;--accent-glow:rgba(124,106,255,.15);
  --green:#34d399;--orange:#fb923c;--red:#f87171;
  --border:#1e1e2e;--border2:#2a2a3a;
  --radius:12px;--radius-lg:20px;
}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none}
img{max-width:100%;display:block}

/* ---- NAV ---- */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;backdrop-filter:blur(20px);background:rgba(5,5,7,.8);border-bottom:1px solid var(--border)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between}
.logo{font-weight:800;font-size:1.25rem;letter-spacing:-.5px;display:flex;align-items:center;gap:8px}
.logo-icon{width:32px;height:32px;background:var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:#fff}
.nav-links{display:flex;gap:32px;align-items:center}
.nav-links a{font-size:.875rem;color:var(--text2);transition:color .2s}
.nav-links a:hover{color:var(--text)}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-weight:600;font-size:.875rem;padding:10px 20px;border-radius:8px;transition:all .2s}
.btn-primary{background:var(--accent);color:#fff}
.btn-primary:hover{background:var(--accent2);transform:translateY(-1px);box-shadow:0 4px 20px rgba(124,106,255,.4)}
.btn-secondary{background:var(--bg3);color:var(--text);border:1px solid var(--border2)}
.btn-secondary:hover{background:var(--bg4);border-color:var(--text3)}
.btn-large{padding:14px 28px;font-size:1rem;border-radius:10px}
.btn-xl{padding:18px 36px;font-size:1.1rem;border-radius:12px}

/* ---- HERO ---- */
.hero{padding:140px 24px 80px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:800px;height:800px;background:radial-gradient(circle,rgba(124,106,255,.08) 0%,transparent 70%);pointer-events:none}
.hero-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 16px;border-radius:999px;background:var(--accent-glow);border:1px solid rgba(124,106,255,.2);font-size:.8rem;color:var(--accent2);margin-bottom:24px}
.hero-badge .dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.hero h1{font-size:clamp(2.5rem,6vw,4.5rem);font-weight:900;letter-spacing:-2px;line-height:1.05;max-width:800px;margin:0 auto 24px}
.hero h1 .gradient{background:linear-gradient(135deg,var(--accent),#c084fc,var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero p{font-size:1.2rem;color:var(--text2);max-width:600px;margin:0 auto 40px;line-height:1.7}
.hero-ctas{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:48px}
.hero-sub{font-size:.8rem;color:var(--text3);margin-bottom:60px}

/* ---- PLATFORM STRIP ---- */
.platforms{display:flex;align-items:center;justify-content:center;gap:40px;opacity:.5;flex-wrap:wrap;padding:0 24px}
.platforms span{font-size:.8rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--text3)}

/* ---- STATS ROW ---- */
.stats{padding:80px 24px;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.stats-inner{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center}
.stat-num{font-size:2.5rem;font-weight:800;letter-spacing:-1px;color:var(--text)}
.stat-num .accent{color:var(--accent)}
.stat-label{font-size:.85rem;color:var(--text3);margin-top:4px}

/* ---- DEMO SECTION ---- */
.demo{padding:100px 24px;max-width:1200px;margin:0 auto}
.section-label{font-size:.75rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:12px}
.section-title{font-size:clamp(2rem,4vw,3rem);font-weight:800;letter-spacing:-1.5px;margin-bottom:16px}
.section-sub{font-size:1.05rem;color:var(--text2);max-width:550px;margin-bottom:48px}
.demo-window{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;position:relative}
.demo-toolbar{padding:12px 20px;background:var(--bg3);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.demo-dot{width:10px;height:10px;border-radius:50%;background:var(--border2)}
.demo-dot:nth-child(1){background:#f87171}
.demo-dot:nth-child(2){background:#fb923c}
.demo-dot:nth-child(3){background:#34d399}
.demo-chat{padding:32px;display:flex;flex-direction:column;gap:20px;min-height:400px}
.chat-msg{display:flex;gap:12px;max-width:85%;animation:fadeUp .4s ease}
.chat-msg.ai{align-self:flex-start}
.chat-msg.user{align-self:flex-end;flex-direction:row-reverse}
.chat-avatar{width:32px;height:32px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700}
.chat-msg.ai .chat-avatar{background:var(--accent-glow);color:var(--accent)}
.chat-msg.user .chat-avatar{background:rgba(52,211,153,.15);color:var(--green)}
.chat-bubble{padding:14px 18px;border-radius:12px;font-size:.9rem;line-height:1.6}
.chat-msg.ai .chat-bubble{background:var(--bg3);color:var(--text)}
.chat-msg.user .chat-bubble{background:rgba(124,106,255,.1);color:var(--text);border:1px solid rgba(124,106,255,.15)}
.tool-call{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:6px;background:rgba(124,106,255,.1);border:1px solid rgba(124,106,255,.15);font-size:.75rem;color:var(--accent2);margin:4px 2px;font-family:'SF Mono',Monaco,monospace}
.tool-call::before{content:'⚡'}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

/* ---- AUDIT TABLE ---- */
.audit-table{width:100%;margin-top:24px;border-collapse:collapse;font-size:.85rem}
.audit-table th{text-align:left;padding:10px 16px;color:var(--text3);font-weight:600;font-size:.75rem;text-transform:uppercase;letter-spacing:1px;border-bottom:1px solid var(--border)}
.audit-table td{padding:10px 16px;border-bottom:1px solid var(--border)}
.score-bar{width:60px;height:6px;border-radius:3px;background:var(--bg4);overflow:hidden;display:inline-block;vertical-align:middle;margin-right:8px}
.score-fill{height:100%;border-radius:3px;transition:width 1s ease}
.score-good{background:var(--green)}
.score-warn{background:var(--orange)}
.score-bad{background:var(--red)}

/* ---- FEATURES GRID ---- */
.features{padding:100px 24px;max-width:1200px;margin:0 auto}
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px}
.feature-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:28px;transition:all .3s}
.feature-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 8px 30px rgba(124,106,255,.1)}
.feature-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:16px}
.feature-card h3{font-size:1.05rem;font-weight:700;margin-bottom:8px}
.feature-card p{font-size:.85rem;color:var(--text2);line-height:1.6}
.fi-purple{background:rgba(124,106,255,.15)}
.fi-green{background:rgba(52,211,153,.15)}
.fi-orange{background:rgba(251,146,60,.15)}
.fi-red{background:rgba(248,113,113,.15)}

/* ---- TOOL COUNTS ---- */
.tool-counts{padding:80px 24px;max-width:1200px;margin:0 auto}
.tc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px}
.tc-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:24px;text-align:center}
.tc-card .count{font-size:2rem;font-weight:800;color:var(--accent)}
.tc-card .platform{font-size:.9rem;font-weight:600;margin:8px 0 4px}
.tc-card .tools-list{font-size:.75rem;color:var(--text3);line-height:1.8}

/* ---- HOW IT WORKS ---- */
.how{padding:100px 24px;max-width:900px;margin:0 auto}
.steps{display:flex;flex-direction:column;gap:0;position:relative}
.steps::before{content:'';position:absolute;left:23px;top:24px;bottom:24px;width:2px;background:var(--border)}
.step{display:flex;gap:24px;padding:24px 0;position:relative}
.step-num{width:48px;height:48px;flex-shrink:0;border-radius:12px;background:var(--bg3);border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem;color:var(--accent);z-index:1}
.step-content h3{font-size:1.1rem;font-weight:700;margin-bottom:4px}
.step-content p{font-size:.9rem;color:var(--text2)}
.step:hover .step-num{background:var(--accent-glow);border-color:var(--accent)}

/* ---- WHY US ---- */
.why{padding:100px 24px;max-width:1200px;margin:0 auto}
.why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px}
.why-card{padding:32px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);position:relative;overflow:hidden}
.why-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent)}
.why-num{font-size:.75rem;font-weight:700;color:var(--accent);margin-bottom:12px;letter-spacing:1px}
.why-card h3{font-size:1.1rem;font-weight:700;margin-bottom:8px}
.why-card p{font-size:.85rem;color:var(--text2);line-height:1.7}

/* ---- PRICING PREVIEW ---- */
.pricing{padding:100px 24px;text-align:center}
.pricing-cards{max-width:900px;margin:48px auto 0;display:grid;grid-template-columns:1fr 1fr;gap:24px}
.price-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:40px 32px;text-align:left;position:relative}
.price-card.featured{border-color:var(--accent);box-shadow:0 0 40px rgba(124,106,255,.15)}
.price-card.featured::before{content:'MOST POPULAR';position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--accent);color:#fff;font-size:.7rem;font-weight:700;padding:4px 16px;border-radius:999px;letter-spacing:1px}
.price-name{font-size:1rem;font-weight:600;color:var(--text2);margin-bottom:8px}
.price-amount{font-size:3rem;font-weight:900;letter-spacing:-2px;margin-bottom:4px}
.price-amount span{font-size:1rem;font-weight:500;color:var(--text3)}
.price-desc{font-size:.85rem;color:var(--text3);margin-bottom:24px}
.price-features{list-style:none;margin-bottom:32px;display:flex;flex-direction:column;gap:12px}
.price-features li{font-size:.875rem;color:var(--text2);display:flex;align-items:center;gap:10px}
.price-features li::before{content:'✓';color:var(--accent);font-weight:700;font-size:.8rem}
.price-btn{width:100%;padding:14px;border-radius:10px;font-weight:700;font-size:.95rem}

/* ---- FAQ ---- */
.faq{padding:100px 24px;max-width:700px;margin:0 auto}
.faq-item{border-bottom:1px solid var(--border)}
.faq-q{width:100%;background:none;color:var(--text);font-size:1rem;font-weight:600;text-align:left;padding:20px 0;display:flex;justify-content:space-between;align-items:center}
.faq-q::after{content:'+';font-size:1.5rem;color:var(--text3);transition:transform .3s}
.faq-q.open::after{transform:rotate(45deg);color:var(--accent)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s ease;font-size:.9rem;color:var(--text2);line-height:1.7}
.faq-a-inner{padding:0 0 20px}

/* ---- BOTTOM CTA ---- */
.bottom-cta{padding:100px 24px;text-align:center;position:relative;overflow:hidden}
.bottom-cta::before{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:800px;height:400px;background:radial-gradient(circle,rgba(124,106,255,.1) 0%,transparent 70%);pointer-events:none}
.bottom-cta h2{font-size:clamp(2rem,4vw,3rem);font-weight:800;letter-spacing:-1px;margin-bottom:16px}
.bottom-cta p{color:var(--text2);max-width:500px;margin:0 auto 32px;font-size:1.05rem}

/* ---- FOOTER ---- */
.footer{padding:40px 24px;border-top:1px solid var(--border);text-align:center;font-size:.8rem;color:var(--text3)}

/* ---- RESPONSIVE ---- */
@media(max-width:768px){
  .nav-links{display:none}
  .stats-inner{grid-template-columns:repeat(2,1fr)}
  .pricing-cards{grid-template-columns:1fr}
  .hero h1{font-size:2.2rem}
  .demo-chat{padding:20px}
  .platforms{gap:20px}
}
@media(max-width:480px){
  .hero{padding:120px 16px 60px}
  .hero-ctas{flex-direction:column;align-items:center}
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="logo">
      <div class="logo-icon">A</div>
      AgencyMCP
    </a>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#demo">Demo</a>
      <a href="#pricing">Pricing</a>
      <a href="#faq">FAQ</a>
      <a href="/pricing" class="btn btn-primary">Get Started</a>
    </div>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-badge">
    <span class="dot"></span>
    350+ tools live on Claude
  </div>
  <h1>AI runs your <span class="gradient">ads, analytics, and SEO</span></h1>
  <p>Connect Google Ads, Meta Ads, GA4, Search Console &amp; Sheets to Claude. Autonomous agents that optimize your marketing around the clock.</p>
  <div class="hero-ctas">
    <a href="/pricing" class="btn btn-primary btn-xl">Start free trial</a>
    <a href="#demo" class="btn btn-secondary btn-xl">See it in action</a>
  </div>
  <p class="hero-sub">14-day free trial &middot; No credit card required &middot; Cancel anytime</p>
  <div class="platforms">
    <span>Works with</span>
    <span style="color:var(--text2);font-weight:700;letter-spacing:0;text-transform:none;font-size:.9rem">Google Ads</span>
    <span style="color:var(--text2);font-weight:700;letter-spacing:0;text-transform:none;font-size:.9rem">Meta Ads</span>
    <span style="color:var(--text2);font-weight:700;letter-spacing:0;text-transform:none;font-size:.9rem">GA4</span>
    <span style="color:var(--text2);font-weight:700;letter-spacing:0;text-transform:none;font-size:.9rem">Search Console</span>
    <span style="color:var(--text2);font-weight:700;letter-spacing:0;text-transform:none;font-size:.9rem">Sheets</span>
  </div>
</section>

<!-- STATS -->
<section class="stats">
  <div class="stats-inner">
    <div><div class="stat-num"><span class="accent counter" data-target="350">0</span>+</div><div class="stat-label">MCP Tools</div></div>
    <div><div class="stat-num"><span class="accent counter" data-target="6">0</span></div><div class="stat-label">Platforms</div></div>
    <div><div class="stat-num"><span class="accent counter" data-target="90">0</span>%</div><div class="stat-label">Tasks automated</div></div>
    <div><div class="stat-num"><span class="accent counter" data-target="5">0</span> min</div><div class="stat-label">Setup time</div></div>
  </div>
</section>

<!-- DEMO -->
<section class="demo" id="demo">
  <div class="section-label">See it work</div>
  <div class="section-title">Watch Claude manage your accounts</div>
  <div class="section-sub">Real tool calls. Real data. Here's what a typical conversation looks like.</div>

  <div class="demo-window">
    <div class="demo-toolbar"><div class="demo-dot"></div><div class="demo-dot"></div><div class="demo-dot"></div><span style="margin-left:12px;font-size:.75rem;color:var(--text3)">Claude &mdash; AgencyMCP connected</span></div>
    <div class="demo-chat" id="demoChat"></div>
  </div>

  <!-- AUDIT TABLE -->
  <div style="margin-top:40px;">
    <div class="section-label">Instant account audit</div>
    <div style="font-size:1.2rem;font-weight:700;margin-bottom:24px">The AI checks 14 dimensions across your entire account</div>
    <div class="demo-window" style="overflow-x:auto">
      <table class="audit-table">
        <thead><tr><th>Dimension</th><th>Score</th><th>Insight</th></tr></thead>
        <tbody>
          <tr><td>Keywords</td><td><span class="score-bar"><span class="score-fill score-good" style="width:90%"></span></span>90%</td><td>Strong coverage. 3 low-QS terms to pause.</td></tr>
          <tr><td>Conversions</td><td><span class="score-bar"><span class="score-fill score-good" style="width:95%"></span></span>95%</td><td>Tracking fires correctly on all pages.</td></tr>
          <tr><td>Budget</td><td><span class="score-bar"><span class="score-fill score-warn" style="width:70%"></span></span>70%</td><td>$412/mo going to junk placements.</td></tr>
          <tr><td>Bidding</td><td><span class="score-bar"><span class="score-fill score-warn" style="width:78%"></span></span>78%</td><td>tCPA set too low — restricting volume.</td></tr>
          <tr><td>Schedule</td><td><span class="score-bar"><span class="score-fill score-bad" style="width:63%"></span></span>63%</td><td>Ads run 24/7 but 0 leads after 9pm.</td></tr>
          <tr><td>Placements</td><td><span class="score-bar"><span class="score-fill score-bad" style="width:55%"></span></span>55%</td><td>34 low-quality sites, zero conversions.</td></tr>
          <tr><td>Targeting</td><td><span class="score-bar"><span class="score-fill score-good" style="width:92%"></span></span>92%</td><td>Well-defined segments. Negative lists maintained.</td></tr>
          <tr><td>Creatives</td><td><span class="score-bar"><span class="score-fill score-good" style="width:89%"></span></span>89%</td><td>Good CTR. Test more vertical video.</td></tr>
          <tr><td>Attribution</td><td><span class="score-bar"><span class="score-fill score-good" style="width:91%"></span></span>91%</td><td>Data-driven model. Cross-device active.</td></tr>
          <tr><td>Negatives</td><td><span class="score-bar"><span class="score-fill score-warn" style="width:68%"></span></span>68%</td><td>Broad match capturing irrelevant queries.</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="features" id="features">
  <div class="section-label">Everything you need</div>
  <div class="section-title">Full command over every ad platform</div>
  <div class="section-sub">350+ tools across 6 platforms. Audit, optimize, create, and report — all through Claude.</div>

  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon fi-purple">🔍</div>
      <h3>Optimize</h3>
      <p>Bid &amp; budget optimization, ROAS improvement, dayparting, audience refinement, placement optimization, device bid adjustments.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon fi-green">✨</div>
      <h3>Create</h3>
      <p>Campaign creation, ad copy testing, keyword expansion, Performance Max setup, responsive search ads, audience building.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon fi-orange">📊</div>
      <h3>Audit</h3>
      <p>Wasted spend detection, negative keyword mining, Quality Score fixes, conversion tracking audit, account structure review.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon fi-red">📈</div>
      <h3>Report</h3>
      <p>Performance reports, budget pacing alerts, competitor benchmarking, attribution analysis, cohort retention, period comparisons.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon fi-green">🔎</div>
      <h3>SEO &amp; Search Console</h3>
      <p>Keyword rankings, click/impression trends, index coverage, URL inspection, mobile usability, Discover &amp; video indexing.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon fi-purple">📉</div>
      <h3>Analytics (GA4)</h3>
      <p>Traffic analysis, cohort retention, attribution paths, predictive metrics, path exploration, custom audiences, date comparisons.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon fi-orange">📱</div>
      <h3>Meta Ads</h3>
      <p>Campaign management, audience targeting, creative performance, ad set optimization, budget allocation, demographic insights.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon fi-red">📋</div>
      <h3>Sheets &amp; Reporting</h3>
      <p>Auto-export data to Google Sheets, custom dashboards, scheduled reports, cross-platform data merging.</p>
    </div>
  </div>
</section>

<!-- TOOL COUNTS -->
<section class="tool-counts">
  <div style="text-align:center;margin-bottom:48px">
    <div class="section-label">Platform coverage</div>
    <div class="section-title">Tools for every platform</div>
  </div>
  <div class="tc-grid">
    <div class="tc-card">
      <div class="count">120+</div>
      <div class="platform">Google Ads</div>
      <div class="tools-list">Campaigns &middot; Keywords &middot; Bidding &middot; P-Max &middot; Shopping &middot; DSA &middot; Audiences</div>
    </div>
