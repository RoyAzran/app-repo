# -----------------------------------------------------------------------------
# Remote MCP Server — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# -----------------------------------------------------------------------------

# -- Security (REQUIRED) ------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# -- Server URL ----------------------------------------------------------------
# Public base URL (no trailing slash) — used for OAuth redirects and billing
BASE_URL=https://your-domain.com
SERVER_BASE_URL=https://your-domain.com

# -- Database ------------------------------------------------------------------
# Leave blank or sqlite:///./data.db for local dev
# Supabase: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# -- Google OAuth --------------------------------------------------------------
# Create at console.cloud.google.com -> APIs & Services -> OAuth 2.0 Client ID
# Authorized redirect URI: {BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# -- Meta / Facebook OAuth ------------------------------------------------------
# Create at developers.facebook.com
META_APP_ID=
META_APP_SECRET=
META_AD_ACCOUNT_ID=act_

# -- Airwallex Billing ---------------------------------------------------------
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_PRODUCT_ID=
AIRWALLEX_WEBHOOK_SECRET=
# Use https://api-demo.airwallex.com for sandbox testing
AIRWALLEX_API_BASE=https://api.airwallex.com

# -- Security Thresholds -------------------------------------------------------
# Unique IPs per JWT in 24h before flagging as credential sharing
SUSPICIOUS_IP_THRESHOLD=5
