# ============================================================
# Agency MCP Server — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ------ Authentication ------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-here

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# ------ Server ------
# Public base URL of this server (no trailing slash)
SERVER_BASE_URL=https://mcp.your-agency.com

# SQLite (default) or PostgreSQL: postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///./agency_mcp.db

# ------ Google OAuth (agency-level — all employees share this) ------
# Create at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorised redirect URI: {SERVER_BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ------ Google Ads (agency MCC level) ------
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# ------ Meta / Facebook (agency app) ------
# Create at developers.facebook.com
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
# Default ad account ID (employees can override per-call)
META_AD_ACCOUNT_ID=act_123456789

# ------ Google Analytics 4 (optional default) ------
# Numeric property ID — employees can pass property_id per-call to override
GA4_PROPERTY_ID=123456789

# ------ Google Search Console (optional default) ------
# e.g. https://www.example.com/ or sc-domain:example.com
GSC_SITE_URL=https://www.your-agency-site.com/
