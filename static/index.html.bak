<script>
// ---- Counter animation ----
const counters = document.querySelectorAll('.counter');
const counterObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const el = entry.target;
      const target = +el.dataset.target;
      const dur = 1500;
      const start = performance.now();
      const tick = (now) => {
        const p = Math.min((now - start) / dur, 1);
        el.textContent = Math.round(target * p);
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
      counterObserver.unobserve(el);
    }
  });
}, { threshold: 0.5 });
counters.forEach(c => counterObserver.observe(c));

// ---- FAQ accordion ----
document.querySelectorAll('.faq-q').forEach(btn => {
  btn.addEventListener('click', () => {
    const a = btn.nextElementSibling;
    const open = btn.classList.toggle('open');
    a.style.maxHeight = open ? a.scrollHeight + 'px' : '0';
  });
});

// ---- Chat demo animation ----
const chatMsgs = [
  { type: 'user', text: 'Give me a full audit of my Google Ads account' },
  { type: 'ai', text: 'I\'ll run a comprehensive audit across all dimensions. Let me pull the data now.\n\n<span class="tool-call">google_ads_account_performance</span> <span class="tool-call">google_ads_keyword_quality</span> <span class="tool-call">google_ads_search_terms</span>' },
  { type: 'ai', text: '<strong>Found 4 issues costing you $640/month:</strong>\n\n1. <strong>$412/mo</strong> going to 34 junk placements — zero conversions\n2. <strong>$148/mo</strong> wasted on overnight ads (0 leads after 9pm in 60 days)\n3. <strong>$80/mo</strong> on irrelevant search terms like "jobs" and "DIY"\n4. Conversion tracking double-counting (~15% inflated)' },
  { type: 'user', text: 'Fix all 4 issues' },
  { type: 'ai', text: 'On it.\n\n<span class="tool-call">google_ads_add_placement_exclusion</span> <span class="tool-call">google_ads_update_ad_schedule</span> <span class="tool-call">google_ads_add_negative_keywords</span>\n\nDone. Estimated impact: <strong>ROAS from 3.8x → 4.4x</strong>, saving <strong>$640/month</strong> while gaining 15-20 more conversions.' },
  { type: 'user', text: 'Now show me GA4 traffic by channel for last month' },
  { type: 'ai', text: '<span class="tool-call">ga4_channel_performance</span>\n\nHere\'s your channel breakdown:\n\n• <strong>Organic Search:</strong> 12,400 sessions (+8%)\n• <strong>Paid Search:</strong> 8,200 sessions (+15%)\n• <strong>Social:</strong> 3,100 sessions (-4%)\n• <strong>Direct:</strong> 5,800 sessions (+2%)\n\nPaid search is your fastest-growing channel. Social dropped — want me to investigate?' },
];

const chatEl = document.getElementById('demoChat');
let msgIdx = 0;
function showNext() {
  if (msgIdx >= chatMsgs.length) { msgIdx = 0; chatEl.innerHTML = ''; setTimeout(showNext, 1000); return; }
  const m = chatMsgs[msgIdx++];
  const div = document.createElement('div');
  div.className = 'chat-msg ' + m.type;
  div.innerHTML = '<div class="chat-avatar">' + (m.type === 'ai' ? 'AI' : 'You') + '</div><div class="chat-bubble">' + m.text + '</div>';
  chatEl.appendChild(div);
  chatEl.scrollTop = chatEl.scrollHeight;
  setTimeout(showNext, m.type === 'user' ? 1500 : 3000);
}

const demoObserver = new IntersectionObserver((entries) => {
  if (entries[0].isIntersecting) { showNext(); demoObserver.disconnect(); }
}, { threshold: 0.3 });
demoObserver.observe(chatEl);
</script>
</body>
</html>
